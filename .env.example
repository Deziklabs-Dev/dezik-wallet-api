# ──────────────────────────────────────────────────────────────
# Dezik Wallet API — Environment Variables
# Copy this file to .env and fill in every value.
# ──────────────────────────────────────────────────────────────

# Database
DATABASE_URL="postgresql://postgres:root@localhost:5440/digital_wallet?schema=public"

# JWT (REQUIRED in production — the app will NOT start without it)
JWT_SECRET="CHANGE_ME_to_a_random_64_char_string"
JWT_EXPIRES_IN="7d"

# Application
PORT=3007
NODE_ENV="development"

# CORS — must point to where the frontend is accessible
FRONTEND_URL="http://localhost:3001"

# Super Admin — the first user created by the seed.
# This same email is used at runtime to grant SUPER_ADMIN privileges.
SUPER_ADMIN_EMAIL="tu_correo@ejemplo.com"
SUPER_ADMIN_PASSWORD="CambiameEnProduccion123!"
